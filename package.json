{
  "name": "al-souq",
  "version": "0.1.0",
  "private": true,
  "description": "السوگ — منصة تجارة إلكترونية متعددة البائعين للسوق العراقي",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @al-souq/db generate",
    "db:migrate": "pnpm --filter @al-souq/db migrate",
    "db:push": "pnpm --filter @al-souq/db push",
    "db:seed": "pnpm --filter @al-souq/db seed",
    "db:studio": "pnpm --filter @al-souq/db studio",
    "vapid": "pnpm --filter @al-souq/api exec web-push generate-vapid-keys"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.6",
    "typescript": "^5.5.3"
  },
  "pnpm": {
    "neverBuiltDependencies": ["@prisma/engines"]
  }
}
