// السوگ (Al-Souq) — مخطط قاعدة البيانات
// PostgreSQL + Prisma
// المبادئ: دقة مالية بـ Decimal، فهارس على مسارات الاستعلام الحرجة،
// لقطات تاريخية للطلبات، حجز مخزون آمن للـ COD.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD // قابل للتوسعة لاحقاً: ZAINCASH, FIB, QI
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

// ─────────────────────────── Identity ───────────────────────────

model User {
  id            String   @id @default(cuid())
  phone         String   @unique // E.164: +9647XXXXXXXXX
  phoneVerified Boolean  @default(false)
  email         String?  @unique
  passwordHash  String? // اختياري — الأساس OTP
  name          String?
  role          Role     @default(CUSTOMER)
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor        VendorProfile?
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  sessions      Session[]
  favorites     Favorite[]
  pushSubs      PushSubscription[]
  auditLogs     AuditLog[]     @relation("ActorLogs")

  @@index([role])
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String // لا يُخزَّن الرمز كنص صريح
  purpose    String    @default("login") // login | verify | reset
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, expiresAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash String    @unique // تجزئة الـ refresh token
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────── Vendor ───────────────────────────

model VendorProfile {
  id             String       @id @default(cuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName      String
  slug           String       @unique
  slugNorm       String // مطبّع للبحث
  description    String?
  logoUrl        String?
  bannerUrl      String?
  status         VendorStatus @default(PENDING)
  // تجاوز اختياري لنسبة العمولة العامة للمنصة (null = استخدم العامة)
  commissionRate Decimal?     @db.Decimal(5, 4)
  governorateId  String?
  governorate    Governorate? @relation(fields: [governorateId], references: [id])
  ratingAvg      Decimal      @default(0) @db.Decimal(3, 2)
  ratingCount    Int          @default(0)
  // تفاصيل التسوية المالية (طريقة الدفع للبائع) — يملؤها البائع
  payoutDetails  Json?
  rejectionNote  String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products Product[]
  orders   Order[]
  payouts  Payout[]

  @@index([status])
  @@index([governorateId])
}

// ─────────────────────────── Catalog ───────────────────────────

model Category {
  id        String     @id @default(cuid())
  nameAr    String
  slug      String     @unique
  icon      String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products Product[]

  @@index([parentId])
}

model Product {
  id          String        @id @default(cuid())
  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  title       String
  titleNorm   String // عنوان مطبّع للبحث العربي
  slug        String        @unique
  description String?
  basePrice   Decimal       @db.Decimal(12, 2) // IQD
  status      ProductStatus @default(DRAFT)
  ratingAvg   Decimal       @default(0) @db.Decimal(3, 2)
  ratingCount Int           @default(0)
  soldCount   Int           @default(0) // عدد القطع المباعة (للتحليلات والترتيب)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  images    ProductImage[]
  variants  ProductVariant[]
  reviews   Review[]
  favorites Favorite[]

  @@index([vendorId, status])
  @@index([categoryId, status])
  @@index([titleNorm])
  @@index([status, createdAt])
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String?
  // سمات المتغيّر، مثل {"اللون":"أحمر","المقاس":"L"}
  attributes    Json    @default("{}")
  price         Decimal @db.Decimal(12, 2)
  stock         Int     @default(0)
  reservedStock Int     @default(0) // محجوز مؤقتاً لطلبات COD قيد الإنشاء
  isActive      Boolean @default(true)

  orderItems   OrderItem[]
  reservations StockReservation[]

  @@unique([productId, sku])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId])
}

// ─────────────────────── Geography (Iraq) ───────────────────────

model Governorate {
  id       String  @id @default(cuid())
  nameAr   String  @unique
  code     String  @unique // كود مختصر، مثل BGD
  sortOrder Int    @default(0)

  areas    Area[]
  addresses Address[]
  vendors  VendorProfile[]
}

model Area {
  id            String      @id @default(cuid())
  nameAr        String
  governorateId String
  governorate   Governorate @relation(fields: [governorateId], references: [id], onDelete: Cascade)

  addresses Address[]

  @@unique([governorateId, nameAr])
  @@index([governorateId])
}

model Address {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  phone         String
  governorateId String
  governorate   Governorate @relation(fields: [governorateId], references: [id])
  areaId        String
  area          Area        @relation(fields: [areaId], references: [id])
  line          String // أقرب نقطة دالة / تفاصيل
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([userId])
}

// ─────────────────────────── Orders ───────────────────────────

model Order {
  id               String        @id @default(cuid())
  number           String        @unique // رقم طلب مقروء، مثل SQ-2406-0001
  customerId       String
  customer         User          @relation(fields: [customerId], references: [id])
  vendorId         String
  vendor           VendorProfile @relation(fields: [vendorId], references: [id])
  status           OrderStatus   @default(PENDING)
  paymentMethod    PaymentMethod @default(COD)
  subtotal         Decimal       @db.Decimal(12, 2)
  deliveryFee      Decimal       @default(0) @db.Decimal(12, 2)
  total            Decimal       @db.Decimal(12, 2)
  commissionRate   Decimal       @db.Decimal(5, 4)
  commissionAmount Decimal       @default(0) @db.Decimal(12, 2)
  // لقطة عنوان التسليم وقت الطلب (لا تتأثر بتعديل العنوان لاحقاً)
  shipTo           Json
  customerNote     String?
  cancelReason     String?
  placedAt         DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  items        OrderItem[]
  history      OrderStatusHistory[]
  commission   Commission?
  reservations StockReservation[]

  @@index([customerId])
  @@index([vendorId, status])
  @@index([status, placedAt])
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  titleSnapshot String // لقطة عنوان المنتج وقت الطلب
  attributesSnapshot Json       @default("{}")
  unitPrice     Decimal         @db.Decimal(12, 2)
  quantity      Int
  lineTotal     Decimal         @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([orderId])
}

model StockReservation {
  id        String            @id @default(cuid())
  variantId String
  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())

  @@index([status, expiresAt])
  @@index([variantId])
}

// ─────────────────────── Money & Settlements ───────────────────────

model Commission {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorId  String
  rate      Decimal  @db.Decimal(5, 4)
  amount    Decimal  @db.Decimal(12, 2)
  payoutId  String?
  payout    Payout?  @relation(fields: [payoutId], references: [id])
  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([payoutId])
}

model Payout {
  id          String        @id @default(cuid())
  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  status      PayoutStatus  @default(PENDING)
  periodStart DateTime
  periodEnd   DateTime
  note        String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  commissions Commission[]

  @@index([vendorId, status])
}

// ─────────────────────────── Engagement ───────────────────────────

model Review {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId   String? // مراجعة موثّقة بطلب فعلي
  rating    Int // 1..5 (يُتحقق في طبقة التطبيق)
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())

  @@unique([userId, productId, orderId])
  @@index([productId, status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // order.status_changed | vendor.approved | ...
  title     String
  body      String?
  data      Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// اشتراك Web Push — يُستخدم في المرحلة 6 لإرسال الإشعارات الفورية.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  action     String // vendor.approve | product.reject | ...
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// ─────────────────────────── Platform ───────────────────────────

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
