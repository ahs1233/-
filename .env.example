# ─────────────────────────────────────────────────────────────
# السوگ (Al-Souq) — مثال متغيرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# ─────────────────────────────────────────────────────────────

# قاعدة البيانات (PostgreSQL)
# DATABASE_URL = اتصال وقت التشغيل (مُجمّع pooled في الإنتاج، مثل Neon pgbouncer)
# DIRECT_URL   = اتصال مباشر للهجرات (محلياً اجعله نفس DATABASE_URL)
DATABASE_URL="postgresql://souq:souq@localhost:5432/al_souq?schema=public"
DIRECT_URL="postgresql://souq:souq@localhost:5432/al_souq?schema=public"

# أسرار JWT — ولّد قيماً عشوائية قوية (مثال: openssl rand -base64 48)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL="900"          # ثوانٍ (15 دقيقة)
JWT_REFRESH_TTL="2592000"     # ثوانٍ (30 يوماً)

# مزوّد الرسائل النصية (OTP)
# console = يطبع الرمز في سجل الخادم أثناء التطوير
# الإنتاج لاحقاً: twilio | zaincash-sms | ...
SMS_PROVIDER="console"

# منطق OTP
OTP_TTL_SECONDS="300"         # صلاحية الرمز (5 دقائق)
OTP_MAX_ATTEMPTS="5"          # محاولات إدخال قبل الإبطال
OTP_LENGTH="6"

# تخزين الصور (S3-compatible — مثل MinIO أو Cloudflare R2)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="al-souq-media"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_PUBLIC_URL="http://localhost:9000/al-souq-media"

# إشعارات Web Push (VAPID) — ولّدها بـ: pnpm vapid
# اتركها فارغة لتعطيل الـ Push (يبقى الإشعار داخل التطبيق يعمل)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@al-souq.iq"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# إعدادات المنصة
PLATFORM_COMMISSION_RATE="0.10"   # 10% نسبة عمولة افتراضية
DEFAULT_LOCALE="ar"

# الواجهة
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
